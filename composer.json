{
    "name": "etechflow/module-mega-menu",
    "description": "Theme-agnostic mega menu for Magento 2. Renders on Hyvä, Luma, Adobe Commerce default and custom themes via automatic runtime detection. Provides a JSON endpoint for lazy-loaded subcategory + featured-product data.",
    "type": "magento2-module",
    "license": "MIT",
    "version": "1.0.0",
    "keywords": [
        "magento",
        "magento2",
        "mega-menu",
        "navigation",
        "hyva",
        "luma",
        "adobe-commerce",
        "etechflow"
    ],
    "authors": [
        {
            "name": "EtechFlow",
            "email": "etechflow0@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "magento/framework": ">=103.0",
        "magento/module-catalog": ">=104.0",
        "magento/module-store": ">=101.0",
        "magento/module-config": ">=101.0",
        "magento/module-theme": ">=101.0"
    },
    "autoload": {
        "files": ["registration.php"],
        "psr-4": {
            "Etechflow\\MegaMenu\\": ""
        }
    }
}
